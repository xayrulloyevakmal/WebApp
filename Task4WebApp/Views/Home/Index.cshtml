@model IEnumerable<Task4WebApp.Models.User>

@{
ViewData["Title"] = "Admin Panel";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    body { font-family: 'Inter', sans-serif; background-color: #f8fafc; }
    .main-card { border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }
    .toolbar-bg { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(10px); }
    .btn-action { transition: all 0.2s ease; border-radius: 8px; font-weight: 500; }
    .btn-action:hover { transform: translateY(-1px); }
    .table thead th { background-color: #f1f5f9; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; color: #64748b; border: none; }
    .user-avatar { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; }
    .status-badge { padding: 0.5em 1em; border-radius: 6px; font-weight: 600; font-size: 0.75rem; }
    .table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.2s; }
    .table tbody tr:hover { background-color: #f8faff; }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">User Management</h2>
            <p class="text-muted mb-0 small">Control user access and monitor system activity</p>
        </div>
        <div class="text-end">
            <span class="text-muted small">Logged in as: <strong>@User.Identity?.Name</strong></span>
        </div>
    </div>

    <div class="card main-card mb-4 toolbar-bg">
        <div class="card-body p-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="d-flex gap-2">
                    <button class="btn btn-danger btn-action shadow-sm d-flex align-items-center" onclick="applyAction('block')">
                        <i class="bi bi-lock-fill me-2"></i> Block
                    </button>
                    <button class="btn btn-light btn-action border shadow-sm d-flex align-items-center" onclick="applyAction('unblock')" title="Unblock">
                        <i class="bi bi-unlock-fill text-warning me-2"></i> Unblock
                    </button>
                    <button class="btn btn-light btn-action border shadow-sm d-flex align-items-center text-danger" onclick="applyAction('delete')" title="Delete">
                        <i class="bi bi-trash3-fill me-2"></i> Delete
                    </button>
                </div>
                <div>
                    <a href="/Account/Logout" class="btn btn-outline-secondary btn-action border-0">
                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card main-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                <tr>
                    <th class="py-3 px-4" style="width: 40px;">
                        <input type="checkbox" id="selectAll" class="form-check-input border-secondary">
                    </th>
                    <th class="py-3">User Information</th>
                    <th class="py-3 text-center">Last Login</th>
                    <th class="py-3 text-center">Status</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var user in Model)
                {
                var isBlocked = user.Status == "Blocked";
                <tr class="@(isBlocked ? "bg-light opacity-75" : "")">
                    <td class="px-4">
                        <input type="checkbox" class="user-checkbox form-check-input" value="@user.Id">
                    </td>
                    <td>
                        <div class="d-flex align-items-center py-1">
                            <div class="user-avatar bg-primary-subtle text-primary me-3">
                                @user.Name[0].ToString().ToUpper()
                            </div>
                            <div>
                                <div class="fw-semibold text-dark">@user.Name</div>
                                <div class="text-muted small">@user.Email</div>
                            </div>
                        </div>
                    </td>
                    <td class="text-center">
                                <span class="text-dark small">
                                    <i class="bi bi-calendar3 me-1 text-muted"></i>
                                    @(user.LastLoginTime?.ToString("MMM dd, HH:mm") ?? "Never logged")
                                </span>
                    </td>
                    <td class="text-center">
                        @if (user.Status == "Active")
                        {
                        <span class="status-badge bg-success-subtle text-success border border-success-subtle">
                                        <i class="bi bi-check-circle-fill me-1"></i> Active
                                    </span>
                        }
                        else
                        {
                        <span class="status-badge bg-danger-subtle text-danger border border-danger-subtle">
                                        <i class="bi bi-x-circle-fill me-1"></i> Blocked
                                    </span>
                        }
                    </td>
                </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    
    document.getElementById('selectAll').onclick = e => {
        document.querySelectorAll('.user-checkbox').forEach(c => c.checked = e.target.checked);
    };
    
    async function applyAction(action) {
        const checkboxes = document.querySelectorAll('.user-checkbox:checked');
        const ids = Array.from(checkboxes).map(c => c.value);
        
        if (ids.length === 0) {
            Swal.fire({ icon: 'warning', title: 'Oops...', text: 'Please select at least one user!' });
            return;
        }

        const params = new URLSearchParams();
        params.append('action', action);
        ids.forEach(id => params.append('ids', id)); 

        try {
            const response = await fetch('/Users/BulkAction', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: params
            });
            
            if (response.ok) {
                window.location.reload();
            } else {
                window.location.href = '/Account/Login';
            }
        } catch (error) {
            console.error('Error:', error);
            window.location.reload();
        }
    }
</script>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>